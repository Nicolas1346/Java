24) Crie uma classe Pessoa com validação:
- nome (somente letras)
- codigo (somente números)
- idade (não negativa)

--------------------------------------------------

public class Pessoa {
    private String nome;
    private String codigo;
    private int idade;

    public void setNome(String nome) {
        if (nome.matches("[a-zA-Z ]+")) {
            this.nome = nome;
        }
    }

    public void setCodigo(String codigo) {
        if (codigo.matches("\\d+")) {
            this.codigo = codigo;
        }
    }

    public void setIdade(int idade) {
        if (idade >= 0) {
            this.idade = idade;
        }
    }
}

